{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Modulus Plugin Manifest",
  "type": "object",
  "required": ["id", "name", "version", "description", "author", "license", "entry", "radix"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Unique plugin identifier (kebab-case)"
    },
    "name": {
      "type": "string",
      "description": "Human-readable plugin name"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+",
      "description": "SemVer version"
    },
    "description": {
      "type": "string",
      "maxLength": 200
    },
    "author": {
      "type": "string"
    },
    "license": {
      "type": "string"
    },
    "icon": {
      "type": "string",
      "description": "Emoji or icon identifier"
    },
    "keywords": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 10
    },
    "homepage": {
      "type": "string",
      "format": "uri"
    },
    "repository": {
      "type": "string"
    },
    "radix": {
      "type": "string",
      "description": "Required pares-radix version range"
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Other modulus plugin IDs this depends on"
    },
    "peerDependencies": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "entry": {
      "type": "string",
      "description": "Path to plugin entry file (relative to plugin dir)"
    },
    "size": {
      "type": "object",
      "properties": {
        "source": { "type": "string" },
        "estimated_bundle": { "type": "string" }
      }
    }
  },
  "additionalProperties": false
}
