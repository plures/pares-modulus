{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "sourceMap": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {
      "@plures/pares-radix": ["./types/pares-radix.d.ts"],
      "@plures/design-dojo": ["./types/design-dojo.d.ts"]
    }
  },
  "include": ["plugins/**/*.ts", "types/**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
